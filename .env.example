# Created by Vercel CLI
VERCEL_OIDC_TOKEN="<your_vercel_oidc_token>"
VITE_GROQ_API_KEY="gsk_<your_groq_api_key>"
VITE_SUPABASE_ANON_KEY="<your_supabase_anon_key>"
