# ── SendGrid Email Notifications ─────────────────────────────────────────────
# Get your API key from: https://app.sendgrid.com/settings/api_keys
# Requires "Mail Send" permission (Full Access or Restricted → Mail Send)
VITE_SENDGRID_API_KEY="SG.REPLACE_WITH_YOUR_SENDGRID_API_KEY"

# The verified sender email address in your SendGrid account
# Must be verified at: https://app.sendgrid.com/settings/sender_auth
VITE_SENDGRID_FROM_EMAIL="noreply@yourdomain.com"
